/*
 * Used when Ninja Forms plugin and fired on all pages within GTM.
 * You can look into passing other info but this is the basic amount of info GTM should use.
 *
 */
<script>
jQuery(function($) {
  $(document).on('nfFormSubmitResponse', function(e, r) {
    var formData = r.response.data,
      formId = formData.form_id,
      formName = formData.settings.title,
      submissionId = formData.actions.save.sub_id;

    dataLayer.push({
      event: 'ninja_form_submission',
      form_id: formId,
      form_name: formName,
      form_submission_id: submissionId
    });
  });
});
</script>

DataLayer Variables:
form_id
form_name
form_submission

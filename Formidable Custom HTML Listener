/*
 * Used when Formidable plugin and fired on all pages within GTM.
 * You can look into passing other info but this is the basic amount of info GTM should use.
 *
 */
<script>
/* Formidable Forms — GTM dataLayer listener */
var frmListener = function() {

  // Fires on every Formidable AJAX submission success
  jQuery('document').on('frmFormComplete', function(event, response, args) {

    var formId   = args.form_id   || '';
    var formKey  = args.form_key  || '';

    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({
      'event'         : 'frm_form_complete',
      'frmFormId'     : formId,
      'frmFormKey'    : formKey
    });

  });

  // Fires on native (non-AJAX) submit — fallback
  jQuery('body').on('submit', '.frm_form_fields', function() {

    var $form   = jQuery(this).closest('form');
    var formId  = $form.find('input[name="form_id"]').val() || '';

    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({
      'event'         : 'frm_form_submit',
      'frmFormId'     : formId
    });

  });

};

// Wait for jQuery + Formidable to be ready
if (typeof jQuery !== 'undefined') {
  frmListener();
} else {
  window.addEventListener('load', frmListener);
}
</script>

Event Trigger:
frm_form_complete

DataLayer Variables:
frmFormId
frmFormKey
